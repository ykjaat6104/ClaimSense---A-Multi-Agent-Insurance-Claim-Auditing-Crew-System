# ClaimSense environment template
# Copy to .env and set your own values.

ENVIRONMENT=development

# For Render (production): Render PostgreSQL connection string from dashboard
# For local (development): sqlite:///./claimsense.db
# For local with PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/claimsense
DATABASE_URL=sqlite:///./claimsense.db

# Must be 32+ chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CLAIMSENSE_AUTH_SECRET=replace_with_a_32_plus_character_secret_value
CLAIMSENSE_DEMO_USER=adjuster
CLAIMSENSE_DEMO_PASSWORD=replace_with_demo_password

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# Comma-separated frontend URL(s). For production, set to your Vercel URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# REQUIRED — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
TAVILY_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

MIN_TEXT_CHARS_PER_PAGE=40

# Optional — Celery/Redis for async processing.
# On Render free tier, Celery workers are not supported.
# The app falls back to synchronous inline processing automatically.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

LOG_LEVEL=INFO
