# ClaimSense environment template
# Copy to .env and set your own values.

ENVIRONMENT=development

# Use SQLite locally or PostgreSQL in shared/prod environments.
# Example PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/claimsense
DATABASE_URL=sqlite:///./claimsense.db

# Must be 32+ chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CLAIMSENSE_AUTH_SECRET=replace_with_a_32_plus_character_secret_value
CLAIMSENSE_DEMO_USER=adjuster
CLAIMSENSE_DEMO_PASSWORD=replace_with_demo_password

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Leave blank to run with deterministic local fallbacks where supported.
GEMINI_API_KEY=
TAVILY_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

MIN_TEXT_CHARS_PER_PAGE=40

# Optional for queued async processing.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

LOG_LEVEL=INFO
