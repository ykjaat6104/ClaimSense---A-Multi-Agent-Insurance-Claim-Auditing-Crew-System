# ============================================================================
# ClaimSense Production Configuration Example
# ============================================================================
# Copy this file to .env and fill in your production values.
# NEVER commit .env with real secrets to version control.
#
# To generate secure secrets:
#   - Generate auth secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   - For passwords: Use a secure password manager
#
# ============================================================================

# ============ ENVIRONMENT ============
# Options: development, staging, production
ENVIRONMENT=production

# ============ DATABASE ============
# PostgreSQL connection string
# Format: postgresql+psycopg2://username:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://claimsense_user:CHANGE_ME@db.example.com:5432/claimsense

# ============ AUTHENTICATION ============
# Secret key for JWT signing - MUST be at least 32 characters
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CLAIMSENSE_AUTH_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARS

# Demo user credentials (replace with database lookups in production)
CLAIMSENSE_DEMO_USER=adjuster
CLAIMSENSE_DEMO_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT Algorithm (HS256, HS512, RS256, etc.)
JWT_ALGORITHM=HS256

# JWT token expiration in hours (default: 7 days)
JWT_EXPIRATION_HOURS=168

# ============ CORS & SECURITY ============
# Allowed origins for CORS (comma-separated)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://app.example.com

# ============ GEMINI API ============
# Google Gemini API key for AI-powered claim extraction
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=CHANGE_ME_TO_YOUR_GEMINI_API_KEY

# Gemini model to use (latest: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Gemini embedding model
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ============ FILE PATHS ============
# Directory for uploaded files (use absolute path in production)
UPLOAD_DIR=/var/claimsense/uploads

# Directory for generated reports (use absolute path in production)
REPORTS_DIR=/var/claimsense/reports

# ============ PROCESSING ============
# Minimum text characters per PDF page to consider valid
MIN_TEXT_CHARS_PER_PAGE=40

# ============ LOGGING ============
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============ EXTERNAL SERVICES ============
# Sentry error tracking (optional)
# SENTRY_DSN=https://example@sentry.io/12345

# Redis connection for caching/task queues (optional)
# REDIS_URL=redis://user:password@redis.example.com:6379/0
