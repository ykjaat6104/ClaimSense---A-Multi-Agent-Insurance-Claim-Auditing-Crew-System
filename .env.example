# ClaimSense environment template
# Copy to .env and set your own values.

ENVIRONMENT=production

# Railway: use Railway PostgreSQL plugin — set via dashboard
# Local:   sqlite:///./claimsense.db
DATABASE_URL=sqlite:///./claimsense.db

# Must be 32+ chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CLAIMSENSE_AUTH_SECRET=replace_with_a_32_plus_character_secret_value
CLAIMSENSE_DEMO_USER=adjuster
CLAIMSENSE_DEMO_PASSWORD=replace_with_demo_password

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# Railway: comma-separated frontend URL(s) — set via dashboard
CORS_ORIGINS=http://localhost:8000

# REQUIRED — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
TAVILY_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

MIN_TEXT_CHARS_PER_PAGE=40

# Railway: set via Redis plugin env vars (REDIS_URL)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

LOG_LEVEL=INFO
